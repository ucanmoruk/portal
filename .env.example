# ÜGD Portal — Ortam Değişkenleri
# Bu dosyayı kopyalayıp .env.local adıyla kaydedin ve değerleri doldurun.
# cp .env.example .env.local

# ─── Veritabanı (MSSQL) ────────────────────────────────────────────
DB_SERVER=192.168.x.x
DB_NAME=PortalDB
DB_USER=sa
DB_PASSWORD=

# ─── Auth (next-auth) ──────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=   # openssl rand -base64 32 ile üretin

# ─── E-posta (nodemailer) ──────────────────────────────────────────
# Admin > Ayarlar panelinden de yönetilebilir
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=portal@ugd.com.tr
